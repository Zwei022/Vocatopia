            },
            {
              "en": "Could you tell me where the nearest bookstore is?",
              "zh": "你可以告訴我最近的書店在哪裡嗎？"
            },
            {
              "en": "I wonder if the meeting has already started.",
              "zh": "我在想那個會議是不是已經開始了。"
            }
          ]
