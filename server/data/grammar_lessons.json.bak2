            },
            {
              "en": "I made a card for my teacher last week.",
              "zh": "我上週幫老師做了一張卡片。"
            },
            {
              "en": "Can you show it to me? I can't see it clearly.",
              "zh": "你可以拿給我看嗎？我看不清楚。"
            },
            {
              "en": "She asked a favor of her older brother.",
              "zh": "她請她哥哥幫了一個忙。"
            },
            {
              "en": "Dad ordered a pizza for the whole family.",
              "zh": "爸爸為全家點了一份披薩。"
            },
            {
              "en": "The clerk handed the receipt to my mom.",
              "zh": "店員把收據交給了我媽媽。"
            },
            {
              "en": "I borrowed some money from my best friend.",
              "zh": "我向我最好的朋友借了一些錢。"
            }
          ]
